# Turso/libSQL database for Vercel
TURSO_DATABASE_URL=libsql://your-database-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# WhatsApp provider: fonnte or wablas
WHATSAPP_PROVIDER=fonnte

# Fonnte
FONNTE_TOKEN=your_fonnte_token

# Wablas
WABLAS_BASE_URL=https://your-server.wablas.com
WABLAS_TOKEN=your_wablas_token

# Optional: protect internal notification endpoints
INTERNAL_API_KEY=replace_with_random_secret

# Database seed admin password
SEED_ADMIN_PASSWORD=replace_with_secure_admin_password
